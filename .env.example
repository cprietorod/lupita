# Backend: Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=tu-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Google Sheets — Service Account key (local dev)
# En Cloud Run se omite; usa la SA del contenedor automáticamente
GOOGLE_APPLICATION_CREDENTIALS=credentials/luppita-sa.json

SPREADSHEET_ID=tu-spreadsheet-id-aqui

# Nombre del propietario que usa el agente
LUPPITA_OWNER_NAME=Tu Nombre
